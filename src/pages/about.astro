---
// RYEWORLD — About Page
import NewsTicker from '../components/NewsTicker.astro';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>about ryeworld — ryeworld</title>
  <meta name="description" content="RYEWORLD is local news built for the people who actually live here. Rye, NY." />
  <meta property="og:image" content="/files/ryeworld-icon-social.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Rock+Salt&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red: #E8222A;
      --black: #111;
      --white: #fff;
      --gray: #888880;
      --light: #f7f7f5;
      --border: #f0efeb;
      --nav-height: 56px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Outfit', sans-serif; background: var(--white); color: var(--black); }
    a { text-decoration: none; color: inherit; }

    /* Focus styles */
    a:focus-visible, button:focus-visible, input:focus-visible {
      outline: 2px solid #000;
      outline-offset: 2px;
    }

    /* Animations */
    @keyframes fu { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    /* ======================== */
    /* STICKY NAV (always show) */
    /* ======================== */
    .sticky-nav {
      position: fixed; top: 72px; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(20px);
      border-bottom: 1px solid #eeecea; padding: 0 clamp(16px, 4vw, 48px);
    }
    .sticky-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 10px 0; }
    .sticky-logo { display: flex; align-items: baseline; gap: 2px; }
    .sticky-logo-img { height: 36px; display: block; }
    .sticky-links { display: flex; gap: 24px; align-items: center; }
    .sticky-links a { font-size: 13px; color: rgba(0,0,0,0.25); font-weight: 600; transition: color 0.2s; }
    .sticky-links a:hover { color: #000; }
    .sticky-tip { font-size: 12px; font-weight: 700; color: var(--white); background: var(--red); padding: 8px 20px; border-radius: 24px; }

    /* ========== */
    /* PAGE HERO  */
    /* ========== */
    .page-hero {
      background: var(--black);
      border-radius: 0 0 28px 28px;
      padding: 168px clamp(16px, 4vw, 48px) 52px;
    }
    .page-hero-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .page-hero-label {
      font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
      color: var(--red);
      opacity: 0; animation: fu 0.6s 0.1s forwards;
    }
    .page-hero h1 {
      font-size: clamp(36px, 6vw, 56px); font-weight: 900; color: var(--white);
      line-height: 1.1; margin-top: 8px;
      opacity: 0; animation: fu 0.6s 0.2s forwards;
    }
    .page-hero h1 span { color: var(--red); }
    .page-hero-sub {
      font-size: 16px; font-weight: 500; color: rgba(255,255,255,0.55);
      line-height: 1.65; max-width: 420px; margin-top: 14px;
      opacity: 0; animation: fu 0.6s 0.3s forwards;
    }

    /* ============= */
    /* STORY SECTION */
    /* ============= */
    .story-section {
      max-width: 680px;
      margin: 0 auto;
      padding: clamp(48px, 6vw, 80px) clamp(16px, 4vw, 48px);
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .story-section p {
      font-size: 17px;
      line-height: 1.75;
      color: var(--black);
    }

    /* ================ */
    /* NETWORK SECTION  */
    /* ================ */
    .network-section {
      background: var(--light);
      padding: clamp(48px, 6vw, 80px) clamp(16px, 4vw, 48px);
    }
    .network-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .network-label {
      font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
      color: var(--red);
    }
    .network-inner h2 {
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 900;
      margin-top: 6px;
      line-height: 1.1;
    }
    .network-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 32px;
    }
    .town-card {
      border-radius: 22px;
      padding: 28px;
    }
    .town-card.active-town {
      background: var(--black);
      color: var(--white);
      border: 2px solid var(--red);
    }
    .town-card.coming-soon {
      background: var(--white);
      border: 1.5px solid var(--border);
      opacity: 0.5;
    }
    .town-name {
      font-size: 22px;
      font-weight: 800;
      text-transform: lowercase;
    }
    .town-status {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-top: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .town-status.status-active { color: var(--red); }
    .town-status.status-soon { color: var(--gray); }
    .pulse-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #27AE60;
      display: inline-block;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.3); }
    }
    .town-location {
      font-size: 13px;
      color: var(--gray);
      margin-top: 6px;
    }
    .active-town .town-location {
      color: rgba(255,255,255,0.4);
    }

    /* ================ */
    /* CONTACT SECTION  */
    /* ================ */
    .contact-section {
      max-width: 680px;
      margin: 0 auto;
      padding: clamp(48px, 6vw, 80px) clamp(16px, 4vw, 48px);
    }
    .contact-section h2 {
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 900;
      text-align: center;
      margin-bottom: 32px;
    }
    .contact-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
      border-bottom: 1px solid var(--border);
    }
    .contact-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gray);
    }
    .contact-value {
      font-size: 15px;
      font-weight: 600;
      color: var(--black);
      transition: color 0.2s;
    }
    .contact-value:hover {
      color: var(--red);
    }

    /* ========== */
    /* NEWSLETTER */
    /* ========== */
    .newsletter {
      background: var(--red); padding: clamp(40px, 5vw, 56px) clamp(16px, 4vw, 48px);
      text-align: center; position: relative; overflow: hidden;
    }
    .newsletter-blob1 { position: absolute; top: -80px; right: -40px; width: 300px; height: 300px; border-radius: 50%; background: rgba(0,0,0,0.05); }
    .newsletter-blob2 { position: absolute; bottom: -60px; left: -30px; width: 220px; height: 220px; border-radius: 50%; background: rgba(255,255,255,0.06); }
    .newsletter-inner { position: relative; max-width: 480px; margin: 0 auto; }
    .newsletter-logo { display: flex; align-items: baseline; justify-content: center; gap: 4px; margin-bottom: 4px; }
    .newsletter-logo-img { height: 60px; display: block; margin: 0 auto; }
    .newsletter-subtitle { font-size: 12px; font-weight: 800; letter-spacing: 4px; text-transform: uppercase; color: rgba(0,0,0,0.25); margin-bottom: 8px; }
    .newsletter-desc { font-size: 15px; color: rgba(0,0,0,0.45); line-height: 1.7; margin: 10px 0 24px; }
    .newsletter-form { display: flex; gap: 8px; max-width: 400px; margin: 0 auto; }
    .newsletter-input {
      flex: 1; padding: 13px 18px; border-radius: 14px; border: 2px solid rgba(0,0,0,0.2);
      background: rgba(255,255,255,0.4); font-size: 14px; font-family: 'Outfit', sans-serif;
      outline: none; color: #000;
    }
    .newsletter-btn {
      padding: 13px 26px; border-radius: 14px; border: none; background: #000;
      color: var(--red); font-size: 14px; font-weight: 700; cursor: pointer;
      font-family: 'Outfit', sans-serif; white-space: nowrap;
    }

    /* ====== */
    /* FOOTER */
    /* ====== */
    footer { background: var(--black); padding: 52px clamp(16px, 4vw, 48px) 32px; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 40px; margin-bottom: 40px; }
    .footer-brand { max-width: 260px; }
    .footer-logo { display: flex; align-items: baseline; gap: 2px; }
    .footer-logo-img { height: 48px; display: block; }
    .footer-desc { font-size: 13px; color: rgba(255,255,255,0.28); line-height: 1.7; margin-top: 10px; }
    .footer-social { display: flex; gap: 10px; margin-top: 14px; }
    .footer-social-icon {
      width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.05);
      display: inline-flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer;
      transition: background 0.2s ease-out;
    }
    .footer-social-icon:hover { background: rgba(255,255,255,0.1); }
    .footer-columns { display: flex; gap: 44px; flex-wrap: wrap; }
    .footer-col-title { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.18); margin-bottom: 14px; }
    .footer-col a { display: block; font-size: 13px; color: rgba(255,255,255,0.38); margin-bottom: 10px; transition: color 0.2s; }
    .footer-col a:hover { color: rgba(255,255,255,0.6); }
    .footer-col a.network { color: var(--red); font-weight: 700; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 18px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
    .footer-copy { font-size: 11px; color: rgba(255,255,255,0.12); }

    /* ====== */
    /* MOBILE */
    /* ====== */
    @media (max-width: 768px) {
      .sticky-links a { display: none; }
      .network-grid { grid-template-columns: 1fr 1fr; }
      .contact-row { flex-direction: column; align-items: flex-start; gap: 4px; }
      .newsletter-form { flex-direction: column; }
    }
    @media (max-width: 480px) {
      .network-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <NewsTicker />

  <!-- Sticky Nav (always visible) -->
  <div class="sticky-nav">
    <div class="sticky-inner">
      <a href="/" class="sticky-logo">
        <img src="/files/ryeworld-logo-black.svg" alt="ryeworld" class="sticky-logo-img">
      </a>
      <div class="sticky-links">
        <a href="/news">news</a>
        <a href="/food">food</a>
        <a href="/events">events</a>
        <a href="/things-to-do">things to do</a>
        <a href="/sports">sports</a>
        <a href="/community">community</a>
        <a href="/tip" class="sticky-tip">submit a tip</a>
      </div>
    </div>
  </div>

  <!-- Page Hero -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-label">the mission</div>
      <h1>about <span>ryeworld</span></h1>
      <p class="page-hero-sub">local news built for the people who actually live here.</p>
    </div>
  </div>

  <!-- Story Section -->
  <section class="story-section">
    <p>RYEWORLD started because Rye deserved better than a Facebook group and a patch.com article three days late. We cover what's actually happening — on Purchase Street, at Memorial Field, in City Hall — for the people who walk those blocks every day.</p>
    <p>Every story is written with one question: would a Rye local actually care about this? If the answer is no, we don't publish it. No SEO bait. No regional filler. Just Rye.</p>
    <p>We're building an autonomous local content network — one town at a time. RYEWORLD is the first. More are coming.</p>
  </section>

  <!-- The Network Section -->
  <section class="network-section">
    <div class="network-inner">
      <div class="network-label">the network</div>
      <h2>one town at a time</h2>
      <div class="network-grid">
        <div class="town-card active-town">
          <div class="town-name">ryeworld</div>
          <div class="town-status status-active"><span class="pulse-dot"></span> active</div>
          <div class="town-location">rye, ny</div>
        </div>
        <div class="town-card coming-soon">
          <div class="town-name">larchmontworld</div>
          <div class="town-status status-soon">coming soon</div>
          <div class="town-location">larchmont, ny</div>
        </div>
        <div class="town-card coming-soon">
          <div class="town-name">pelhamworld</div>
          <div class="town-status status-soon">coming soon</div>
          <div class="town-location">pelham, ny</div>
        </div>
        <div class="town-card coming-soon">
          <div class="town-name">mamaroneckworld</div>
          <div class="town-status status-soon">coming soon</div>
          <div class="town-location">mamaroneck, ny</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <h2>get in touch</h2>
    <div class="contact-row">
      <span class="contact-label">tips</span>
      <a href="mailto:tips@ryeworld.world" class="contact-value">tips@ryeworld.world</a>
    </div>
    <div class="contact-row">
      <span class="contact-label">advertising</span>
      <a href="mailto:ads@ryeworld.world" class="contact-value">ads@ryeworld.world</a>
    </div>
    <div class="contact-row">
      <span class="contact-label">general</span>
      <a href="mailto:hello@ryeworld.world" class="contact-value">hello@ryeworld.world</a>
    </div>
    <div class="contact-row">
      <span class="contact-label">socials</span>
      <a href="#" class="contact-value">@RyeWorldNY</a>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <div class="newsletter">
    <div class="newsletter-blob1"></div>
    <div class="newsletter-blob2"></div>
    <div class="newsletter-inner">
      <div class="newsletter-logo"><img src="/files/ryeworld-logo-black-on-red.svg" alt="ryeworld" class="newsletter-logo-img"></div>
      <div class="newsletter-subtitle">the weekly drop</div>
      <p class="newsletter-desc">Everything that happened + everything coming up.<br/>Every Monday. Free.</p>
      <div class="newsletter-form">
        <input type="email" class="newsletter-input" placeholder="your@email.com" />
        <button class="newsletter-btn">subscribe →</button>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo"><img src="/files/ryeworld-logo-white.svg" alt="ryeworld" class="footer-logo-img"></div>
          <p class="footer-desc">News, food, events & community for the city on the Sound.</p>
          <div class="footer-social">
            <span class="footer-social-icon">📸</span>
            <span class="footer-social-icon">🎬</span>
            <span class="footer-social-icon">📧</span>
          </div>
        </div>
        <div class="footer-columns">
          <div>
            <div class="footer-col-title">Sections</div>
            <div class="footer-col"><a href="/news">News</a><a href="/food">Food & Drink</a><a href="/events">Events</a><a href="/things-to-do">Things to Do</a><a href="/sports">Sports</a><a href="/community">Community</a></div>
          </div>
          <div>
            <div class="footer-col-title">More</div>
            <div class="footer-col"><a href="/about">About</a><a href="/about">Advertise</a><a href="/tip">Submit a Tip</a><a href="#newsletter">Newsletter</a><a href="/privacy">Privacy</a></div>
          </div>
          <div>
            <div class="footer-col-title">The Network</div>
            <div class="footer-col">
              <a href="#" class="network">RyeWorld</a>
              <a href="#" class="network">LarchmontWorld</a>
              <a href="#" class="network">PelhamWorld</a>
              <a href="#" class="network">MamaroneckWorld</a>
              <a href="#">Coming Soon...</a>
            </div>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">© 2026 RyeWorld · Part of the [Town]World network</span>
        <span class="footer-copy">Posts may contain affiliate links</span>
      </div>
    </div>
  </footer>

</body>
</html>