  <!-- JavaScript -->
  <script>
    // Category filter
    const pills = document.querySelectorAll('.filter-pill');
    const cards = document.querySelectorAll('.event-card');
    const dayGroups = document.querySelectorAll('.day-group');
    const emptyState = document.getElementById('emptyState');
    const emptyText = document.getElementById('emptyText');

    const categoryLabels = {
      all: '', sports: 'sports', arts: 'arts', food: 'food & drink',
      community: 'community', kids: 'kids', town: 'town'
    };

    function filterEvents(cat) {
      // Update pills
      pills.forEach(p => p.classList.toggle('active', p.dataset.filter === cat));

      let totalVisible = 0;

      dayGroups.forEach(group => {
        const groupCards = group.querySelectorAll('.event-card');
        let groupVisible = 0;

        groupCards.forEach(card => {
          const show = cat === 'all' || card.dataset.category === cat;
          if (show) {
            card.style.display = 'flex';
            card.classList.remove('hiding');
            card.classList.add('showing');
            groupVisible++;
          } else {
            card.classList.remove('showing');
            card.classList.add('hiding');
            // Hide after transition
            setTimeout(() => {
              if (card.classList.contains('hiding')) {
                card.style.display = 'none';
              }
            }, 200);
          }
        });

        // Update count
        const countEl = group.querySelector('.count');
        if (countEl) {
          countEl.textContent = groupVisible + ' event' + (groupVisible !== 1 ? 's' : '');
        }

        // Hide entire group if no visible events
        if (groupVisible === 0) {
          group.classList.add('hiding');
        } else {
          group.classList.remove('hiding');
        }

        totalVisible += groupVisible;
      });

      // Empty state
      if (totalVisible === 0 && emptyState && emptyText) {
        const label = categoryLabels[cat] || cat;
        emptyText.textContent = cat === 'all'
          ? 'nothing on the calendar this week'
          : `no ${label} events this week`;
        emptyState.classList.add('visible');
      } else if (emptyState) {
        emptyState.classList.remove('visible');
      }

      // Update URL
      const url = new URL(window.location.href);
      if (cat === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', cat);
      }
      history.pushState(null, '', url.toString());
    }

    // Pill click handlers
    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        filterEvents(pill.dataset.filter);
      });
    });

    // Read URL params on load
    const params = new URLSearchParams(window.location.search);
    const initialCat = params.get('category');
    if (initialCat && categoryLabels.hasOwnProperty(initialCat)) {
      filterEvents(initialCat);
    }

    // Week nav buttons (no-op for now)
    document.getElementById('weekPrev')?.addEventListener('click', () => {});
    document.getElementById('weekNext')?.addEventListener('click', () => {});
  </script>

