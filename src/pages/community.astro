---
// RYEWORLD — Community Groups
import NewsTicker from '../components/NewsTicker.astro';

// Community groups data
const groups = [
  {
    id: 'parents',
    name: 'rye parents',
    emoji: '👶',
    description: 'schools, childcare, playdates, camps, and raising kids in rye.',
    members: 847,
    color: '#E8222A',
