---
// RYEWORLD — Astro Homepage
import NewsTicker from '../components/NewsTicker.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const shown = new Set([
  'garnets-hockey-state-semis','the-snackery-closes-purchase-street','coffee-shops-ranked',
  'spring-sports-preview-2026','playland-2026-season-preview','rye-comprehensive-plan-285k-rewrite',
  'spring-in-rye-whats-coming','autumn-terrill-human-rights-award','this-weekend-in-rye',
]);
const feedArticles = allArticles
  .filter(a => !shown.has(a.data.slug))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const feedImages: Record<string, string> = {
  'rye-school-board-election-may-2026': '/images/rye-school-board-election-may-2026.jpg',
  'garnets-lax-season-preview': '/images/garnets-lax-season-preview.jpg',
  'rye-fire-truck-1-47m-pierce-pumper': '/images/rye-fire-truck-1-47m-pierce-pumper.jpg',
  'earthquake-2-3-magnitude-rye': '/images/crawford-park-rye.jpg',
  'purchase-street-dining-guide': '/images/the-snackery-closes-purchase-street.jpg',
  'playland-job-fair-saturday': '/images/playland-beach.jpg',
  'new-to-rye-handbook': '/images/meadow-view-rye.jpg',
};
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RYEWORLD — Your Town on the Sound</title>
  <meta name="description" content="News, food, events & community for Rye, NY. Written for the people who actually live here." />
  <meta property="og:image" content="/files/ryeworld-icon-social.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Rock+Salt&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --red: #E8222A;
      --black: #111;
      --white: #fff;
      --gray: #888880;
      --light: #f7f7f5;
      --border: #f0efeb;
      --cream: #faf6f0;
      --sage: #e8ede4;
      --tan: #f0e6d8;
      --blush: #fdf0ef;
      --ink: #1a1a18;
      --paper: #FAF8F4;
    }
    html { scroll-behavior: smooth; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Outfit', sans-serif; background: var(--paper); color: var(--black); }
    a { text-decoration: none; color: inherit; }

    /* Hero */
    .hero {
      min-height: 100vh; background: var(--red); display: flex; flex-direction: column;
      overflow: hidden; position: relative;
    }
    .hero-nav {
      display: flex; justify-content: space-between; align-items: center;
      padding: 20px clamp(20px, 4vw, 48px); position: relative; z-index: 10;
    }
    .hero-nav-links { display: flex; gap: 24px; }
    .hero-nav-links a { font-size: 13px; color: rgba(255,255,255,0.55); font-weight: 600; transition: color 0.2s; }
    .hero-nav-links a:hover { color: #fff; }
    .hero-tip-btn {
      font-size: 12px; font-weight: 700; color: var(--red); background: #000;
      padding: 10px 24px; border-radius: 28px; cursor: pointer;
    }
    .hero-center {
      flex: 1; display: flex; flex-direction: column; align-items: center;
      justify-content: center; padding: 0 20px; text-align: center;
    }
    .hero-grain {
      position: absolute; inset: 0; opacity: 0.04;
      background-image: radial-gradient(circle at 25% 25%, #000 1px, transparent 1px);
      background-size: 22px 22px; pointer-events: none;
    }
    .hero-label {
      font-size: 18px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase;
      color: rgba(255,255,255,0.45); margin-bottom: 14px;
      opacity: 0; animation: fu 0.6s 0.2s forwards;
    }
    .hero-logo {
      display: block; max-width: clamp(320px, 60vw, 560px); width: 100%; height: auto;
      opacity: 0; animation: glitchIn 0.6s 0.3s forwards;
      cursor: pointer;
    }
    .hero-logo.glitch {
      animation: glitchClick 0.35s ease-out;
    }
    .hero-logo-svg { width: 100%; height: auto; display: block; }
    .lon { animation: meridianSpin 25s linear infinite; opacity: 0.6; }
    .lon-1 { animation-delay: 0s; }
    .lon-2 { animation-delay: -5s; }
    .lon-3 { animation-delay: -10s; }
    .lon-4 { animation-delay: -15s; }
    .lon-5 { animation-delay: -20s; }
    @keyframes meridianSpin {
      0%, 100% { rx: 1; }
      10% { rx: 46; }
      20% { rx: 88; }
      30% { rx: 121; }
      40% { rx: 143; }
      50% { rx: 150; }
      60% { rx: 143; }
      70% { rx: 121; }
      80% { rx: 88; }
      90% { rx: 46; }
    }

    /* Glitch-in: transparent → visible with slicing/displacement, no color */
    @keyframes glitchIn {
      0%   { opacity: 0; clip-path: inset(0 0 100% 0); }
      10%  { opacity: 1; clip-path: inset(0 0 60% 0); transform: translateX(-12px) skewX(-3deg); }
      15%  { clip-path: inset(30% 0 20% 0); transform: translateX(8px) skewX(2deg); }
      20%  { clip-path: inset(0 0 40% 0); transform: translateX(-5px); }
      25%  { clip-path: inset(50% 0 0 0); transform: translateX(10px) skewX(-4deg); }
      30%  { clip-path: inset(10% 0 10% 0); transform: translateX(-3px) skewX(1deg); }
      38%  { clip-path: inset(0 0 5% 0); transform: translateX(4px); }
      45%  { clip-path: inset(60% 0 0 0); transform: translateX(-6px) skewX(-2deg); }
      50%  { clip-path: inset(5% 0 0 0); transform: translateX(2px); }
      60%  { clip-path: inset(0); transform: translateX(-1px); }
      70%  { clip-path: inset(40% 0 40% 0); transform: none; }
      75%  { clip-path: inset(0); transform: translateX(1px); }
      85%  { clip-path: inset(0); transform: none; }
      100% { opacity: 1; clip-path: inset(0); transform: none; }
    }
    @keyframes glitchClick {
      0%   { clip-path: inset(0); transform: none; }
      10%  { clip-path: inset(20% 0 30% 0); transform: translateX(-8px) skewX(-4deg); }
      20%  { clip-path: inset(50% 0 10% 0); transform: translateX(6px) skewX(3deg); }
      30%  { clip-path: inset(10% 0 50% 0); transform: translateX(-4px); }
      40%  { clip-path: inset(0 0 20% 0); transform: translateX(3px) skewX(-1deg); }
      55%  { clip-path: inset(0); transform: translateX(-1px); }
      100% { clip-path: inset(0); transform: none; }
    }
    .hero-tagline {
      font-size: 15px; color: rgba(255,255,255,0.6); font-weight: 500;
      margin-top: 32px; line-height: 1.65; max-width: 340px;
      opacity: 0; animation: fu 0.6s 0.6s forwards;
    }
    .hero-ctas {
      display: flex; gap: 12px; margin-top: 24px;
      opacity: 0; animation: fu 0.6s 0.75s forwards;
    }
    .btn-primary {
      padding: 12px 28px; border-radius: 28px; background: #000; color: var(--red);
      font-size: 14px; font-weight: 700; cursor: pointer; border: none; font-family: 'Outfit', sans-serif;
    }
    .btn-outline {
      padding: 12px 28px; border-radius: 28px; border: 2px solid rgba(255,255,255,0.35);
      color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; background: none; font-family: 'Outfit', sans-serif;
    }
    .scroll-pill {
      text-align: center; padding-bottom: 20px;
      opacity: 0; animation: fu 0.6s 0.9s forwards;
    }
    .scroll-pill-inner {
      width: 24px; height: 40px; border: 2px solid rgba(0,0,0,0.18);
      border-radius: 12px; margin: 0 auto; position: relative;
    }
    .scroll-dot {
      width: 4px; height: 8px; background: rgba(0,0,0,0.25); border-radius: 2px;
      position: absolute; top: 8px; left: 50%; margin-left: -2px;
      animation: sd 1.5s ease-in-out infinite;
    }

    /* Marquee */
    .marquee-wrap { overflow: hidden; padding: 18px 0; border-bottom: 1px solid var(--border); }
    .marquee-track { display: flex; white-space: nowrap; animation: mq 36s linear infinite; align-items: center; }
    .marquee-text {
      font-size: clamp(28px, 4vw, 38px); font-weight: 900; letter-spacing: 4px; text-transform: uppercase;
      color: var(--red); margin: 0; font-style: italic;
    }
    .marquee-text.flip {
      display: inline-block; transform: rotate(180deg);
    }
    .marquee-sym { font-size: clamp(20px, 3vw, 30px); color: var(--red); margin: 0 16px; opacity: 0.5; font-style: normal; font-weight: 300; }

    /* Sticky nav */
    .sticky-nav {
      position: fixed; top: 72px; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(20px);
      border-bottom: 1px solid #eeecea; padding: 0 clamp(16px, 4vw, 48px);
      transform: translateY(-150%); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
    }
    .sticky-nav.show { transform: translateY(0); }
    .sticky-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 10px 0; }
    .sticky-logo { display: flex; align-items: baseline; gap: 2px; }
    .sticky-logo-img { height: 36px; display: block; }
    .sticky-links { display: flex; gap: 24px; align-items: center; }
    .sticky-links a { font-size: 13px; color: rgba(0,0,0,0.25); font-weight: 600; transition: color 0.2s; }
    .sticky-links a:hover { color: #000; }
    .sticky-tip { font-size: 12px; font-weight: 700; color: var(--white); background: var(--red); padding: 8px 20px; border-radius: 24px; }

    /* Content wrapper */
    #content { position: relative; }
    #content::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 256px 256px;
    }
    .content-wrap { max-width: 1200px; margin: 0 auto; padding: 0 clamp(16px, 4vw, 48px); }

    /* Section label */
    .section-label {
      font-size: 10px; font-weight: 800; letter-spacing: 3px; text-transform: uppercase;
      color: var(--red);
    }

    /* Bento grid — asymmetric magazine layout */
    .bento {
      display: grid; grid-template-columns: 5fr 4fr 3fr; grid-template-rows: auto;
      gap: 7px; margin: clamp(28px, 4vw, 48px) 0 7px;
    }

    /* Card base */
    .card {
      border-radius: 28px; overflow: hidden; position: relative;
      cursor: pointer; display: flex; flex-direction: column;
      transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
      border: none;
      box-shadow: 0 2px 8px rgba(42,42,40,0.06), 0 1px 2px rgba(42,42,40,0.04);
    }
    .card:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(42,42,40,0.10); }
    .card img, .card-img { filter: saturate(0.92) contrast(1.03) brightness(1.01); transition: filter 0.3s ease-out; }
    .card:hover img, .card:hover .card-img { filter: saturate(1.0) contrast(1.0) brightness(1.0); }

    /* Image cards */
    .card-img {
      width: 100%; object-fit: cover; display: block; flex: 1; min-height: 0;
    }

    /* Card with image + text overlay at bottom */
    .card-overlay-bottom {
      position: relative; display: flex; flex-direction: column;
    }
    .card-overlay-bottom .card-img { flex: 1; }
    .card-overlay-bottom .card-text-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 24px;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.35) 70%, transparent 100%);
    }
    .card-overlay-bottom .card-cat-line {
      font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.6);
    }
    .card-overlay-bottom .card-cat-line span { margin: 0 6px; opacity: 0.4; }
    .card-overlay-bottom .card-title {
      font-size: clamp(20px, 2.2vw, 28px); font-weight: 900; line-height: 1.1;
      color: #fff; text-transform: uppercase; letter-spacing: -0.3px; margin-top: 8px;
    }

    /* Text-dominant card (no image, big bold headline) */
    .card-text {
      padding: clamp(24px, 3vw, 36px); display: flex; flex-direction: column;
      justify-content: space-between; background: var(--ink);
      transform: rotate(-1.5deg); transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
    }
    .card-text:hover { transform: rotate(0deg) translateY(-4px); }
    .card-text .card-cat-line {
      font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.55);
    }
    .card-text .card-cat-line span { margin: 0 6px; opacity: 0.4; }
    .card-text .card-title {
      font-size: clamp(22px, 2.5vw, 32px); font-weight: 900; line-height: 1.1;
      text-transform: uppercase; letter-spacing: -0.3px; margin-top: 14px;
      color: #fff;
    }
    .card:hover .card-text .card-title { color: var(--red); }
    .card-text .card-excerpt {
      font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.6; margin-top: 14px;
      font-weight: 400;
    }
    .card-text .card-read-more {
      font-size: 13px; color: var(--red); margin-top: auto; padding-top: 16px;
    }

    /* Image card with text below */
    .card-img-below { background: var(--light); }
    .card-img-below .card-img { aspect-ratio: 4/5; }
    .card-img-below .card-body { padding: 16px 20px 22px; }
    .card-img-below .card-cat-line {
      font-size: 11px; font-weight: 600; color: var(--gray);
    }
    .card-img-below .card-cat-line span { margin: 0 6px; opacity: 0.4; }
    .card-img-below .card-title {
      font-size: 16px; font-weight: 800; line-height: 1.2; margin-top: 6px;
      text-transform: uppercase; letter-spacing: -0.2px;
    }
    .card:hover .card-img-below .card-title,
    .card-img-below:hover .card-title { color: var(--red); }

    /* Arrow link rows */
    .link-rows { display: flex; flex-direction: column; border-top: 1px solid rgba(255,255,255,0.12); }
    .link-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.12);
      font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
      cursor: pointer; transition: color 0.2s; color: #fff;
    }
    .link-row:hover { color: var(--red); }
    .link-arrow {
      width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.2);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 14px; transition: all 0.2s; flex-shrink: 0;
    }
    .link-row:hover .link-arrow { border-color: var(--red); color: var(--red); }

    /* Category pill cloud card */
    .card-categories {
      padding: clamp(24px, 3vw, 32px); display: flex; flex-direction: column;
      justify-content: space-between; background: var(--cream);
      transform: rotate(1deg); transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
    }
    .card-categories:hover { transform: rotate(0deg) translateY(-4px); }
    .cat-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .cat-pill {
      font-size: 12px; font-weight: 700; padding: 8px 16px; border-radius: 20px;
      border: 1.5px solid rgba(232,34,42,0.2); background: #fff;
      transition: all 0.2s; cursor: pointer; color: var(--black);
    }
    .cat-pill:hover { border-color: var(--red); color: var(--red); background: #fff; }
    .cat-view-all {
      display: flex; align-items: center; gap: 10px; margin-top: auto; padding-top: 16px;
      font-size: 14px; font-weight: 700; cursor: pointer; color: var(--red);
    }
    .cat-view-all:hover { opacity: 0.7; }

    /* Tall card — spans 2 rows */
    .card-tall { grid-row: span 2; }

    /* Placeholder images — gradient blocks until real photos */
    .ph { display: block; width: 100%; height: 100%; min-height: 200px; }
    .ph-food { background: linear-gradient(145deg, #f4e8d1 0%, #e8c8a0 100%); }
    .ph-sport { background: linear-gradient(145deg, #d4e8d1 0%, #8cb88a 100%); }
    .ph-beach { background: linear-gradient(145deg, #d1e4f4 0%, #89b8d8 100%); }
    .ph-town { background: linear-gradient(145deg, #f0e6e6 0%, #d4b0b0 100%); }
    .ph-event { background: linear-gradient(145deg, #e8e0f4 0%, #b8a0d4 100%); }
    .ph-coffee { background: linear-gradient(145deg, #e8ddd1 0%, #c4a882 100%); }
    .ph-play { background: linear-gradient(145deg, #f4e4d4 0%, #d4a878 100%); }

    /* Second row bento */
    .bento-2 {
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 7px;
      margin-bottom: 7px;
    }

    /* Evergreen feed */
    .feed-grid {
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 7px;
      margin-bottom: 7px;
    }
    .feed-hidden { display: none; }

    /* Events — clean & minimal */
    .events-section { margin-top: 8px; }
    .events-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; }
    .events-title { font-size: clamp(26px, 3.5vw, 38px); font-weight: 800; line-height: 1.1; margin-top: 6px; }
    .events-title span { color: var(--red); }
    .events-link { font-size: 13px; font-weight: 700; color: var(--red); transition: opacity 0.2s; }
    .events-link:hover { opacity: 0.7; }
    .events-list { border-top: 1px solid var(--border); }
    .event-row {
      display: grid; grid-template-columns: 80px 1fr auto; gap: 16px; align-items: baseline;
      padding: 18px 0; border-bottom: 1px solid var(--border); cursor: pointer;
      transition: background 0.2s;
    }
    .event-row:hover { background: var(--light); margin: 0 -12px; padding-left: 12px; padding-right: 12px; border-radius: 12px; }
    .event-date { font-size: 13px; font-weight: 800; color: var(--red); text-transform: uppercase; }
    .event-name { font-size: 17px; font-weight: 700; line-height: 1.25; }
    .event-where { font-size: 13px; color: var(--gray); text-align: right; }

    /* Newsletter */
    .newsletter {
      background: var(--red); border-radius: 28px; padding: clamp(40px, 5vw, 60px);
      text-align: center; position: relative; overflow: hidden; margin-top: 40px;
    }
    .newsletter-inner { position: relative; max-width: 480px; margin: 0 auto; }
    .newsletter-logo-img { height: 60px; display: block; margin: 0 auto 4px; }
    .newsletter-subtitle { font-size: 12px; font-weight: 800; letter-spacing: 4px; text-transform: uppercase; color: rgba(0,0,0,0.25); margin-bottom: 8px; }
    .newsletter-desc { font-size: 15px; color: rgba(0,0,0,0.45); line-height: 1.7; margin: 10px 0 24px; }
    .newsletter-form { display: flex; gap: 8px; max-width: 400px; margin: 0 auto; }
    .newsletter-input {
      flex: 1; padding: 14px 18px; border-radius: 14px; border: 2px solid rgba(0,0,0,0.15);
      background: rgba(255,255,255,0.5); font-size: 14px; font-family: 'Outfit', sans-serif;
      outline: none; color: #000;
    }
    .newsletter-input::placeholder { color: rgba(0,0,0,0.3); }
    .newsletter-input:focus { border-color: #000; background: rgba(255,255,255,0.7); }
    .newsletter-btn {
      padding: 14px 28px; border-radius: 14px; border: none; background: #000;
      color: var(--red); font-size: 14px; font-weight: 700; cursor: pointer;
      font-family: 'Outfit', sans-serif; white-space: nowrap;
      transition: transform 0.2s;
    }
    .newsletter-btn:hover { transform: scale(1.03); }

    /* Tip banner */
    .tip-banner {
      border: 2px solid var(--border); border-radius: 28px; padding: clamp(28px, 3.5vw, 44px);
      display: flex; justify-content: space-between; align-items: center; gap: 24px;
      margin-top: 14px; cursor: pointer; transition: all 0.3s;
    }
    .tip-banner:hover { border-color: var(--red); background: rgba(232,34,42,0.02); }
    .tip-title { font-size: clamp(20px, 2.5vw, 28px); font-weight: 800; line-height: 1.15; }
    .tip-title span { color: var(--red); }
    .tip-desc { font-size: 13px; color: var(--gray); margin-top: 6px; }
    .tip-btn {
      font-size: 13px; font-weight: 700; color: var(--white); background: var(--red);
      padding: 13px 30px; border-radius: 24px; white-space: nowrap; flex-shrink: 0;
      transition: transform 0.25s;
    }
    .tip-banner:hover .tip-btn { transform: scale(1.04); }

    /* Footer */
    footer { background: var(--black); padding: 52px clamp(16px, 4vw, 48px) 32px; margin-top: 28px; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 40px; margin-bottom: 40px; }
    .footer-brand { max-width: 260px; }
    .footer-logo { display: flex; align-items: baseline; gap: 2px; }
    .footer-logo-img { height: 48px; display: block; }
    .footer-desc { font-size: 13px; color: rgba(255,255,255,0.28); line-height: 1.7; margin-top: 10px; }
    .footer-social { display: flex; gap: 10px; margin-top: 14px; }
    .footer-social-icon {
      width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.05);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 800; letter-spacing: 0.5px; color: rgba(255,255,255,0.4);
      cursor: pointer; transition: background 0.2s;
    }
    .footer-social-icon:hover { background: rgba(255,255,255,0.1); color: var(--red); }
    .footer-columns { display: flex; gap: 44px; flex-wrap: wrap; }
    .footer-col-title { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.18); margin-bottom: 14px; }
    .footer-col a { display: block; font-size: 13px; color: rgba(255,255,255,0.38); margin-bottom: 10px; }
