  <script>
    // Sticky nav scroll trigger
    const stickyNav = document.getElementById('stickyNav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > window.innerHeight * 0.85) {
        stickyNav.classList.add('show');
      } else {
        stickyNav.classList.remove('show');
      }
    });

    // Glitch on click — logo and anywhere on hero
    const heroLogo = document.querySelector('.hero-logo');
    const hero = document.getElementById('hero');
    if (heroLogo && hero) {
      hero.addEventListener('click', () => {
        heroLogo.classList.remove('glitch');
        void heroLogo.offsetWidth; // force reflow
        heroLogo.classList.add('glitch');
        heroLogo.addEventListener('animationend', () => {
          heroLogo.classList.remove('glitch');
        }, { once: true });
      });
    }
    // Newsletter subscription feedback
    document.querySelectorAll('.newsletter-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const input = btn.parentElement.querySelector('.newsletter-input');
        if (!input || !input.value.trim() || !input.value.includes('@')) return;
        e.preventDefault();
        const orig = btn.textContent;
        btn.textContent = 'subscribed!';
        btn.style.background = '#27AE60';
        input.value = '';
        setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 2500);
      });
    });

    // Evergreen feed — reveal hidden cards as user scrolls
    const hidden = Array.from(document.querySelectorAll('.feed-hidden'));
    const sentinel = document.getElementById('feedSentinel');
    const BATCH = 3;
    function revealMore() {
      const batch = hidden.splice(0, BATCH);
      batch.forEach(el => el.classList.remove('feed-hidden'));
      if (!hidden.length) feedObserver.disconnect();
    }
    const feedObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && hidden.length) revealMore();
    }, { rootMargin: '200px' });
    feedObserver.observe(sentinel);
  </script>

