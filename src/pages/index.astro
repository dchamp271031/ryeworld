    @keyframes ryePop { from { opacity: 0; transform: scale(0.92); } to { opacity: 1; transform: scale(1); } }
    @keyframes sd { 0%, 100% { opacity: 0.3; transform: translateY(0); } 50% { opacity: 0.8; transform: translateY(14px); } }
    @keyframes mq { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }

    /* Mobile */
    @media (max-width: 768px) {
      .hero-nav-links { display: none; }
